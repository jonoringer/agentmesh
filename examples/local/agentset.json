{
  "apiVersion": "agentmesh.dev/v1alpha1",
  "kind": "AgentSet",
  "metadata": {
    "name": "support-router-set"
  },
  "spec": {
    "selector": {
      "matchLabels": {
        "app": "support-router"
      }
    },
    "template": {
      "ref": "support-router"
    },
    "replicas": {
      "min": 1,
      "max": 4,
      "desired": 2
    },
    "rollout": {
      "strategy": "rolling",
      "maxUnavailable": 1
    }
  }
}
